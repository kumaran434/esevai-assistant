{
  "name": "react-example",
  "private": true,
  "version": "1.1.6",
  "description": "AI-powered document extraction and form filling assistant for E-Sevai portals. Features include ID cropping, signature generation, and automated data entry.",
  "author": "E-Sevai AI Center <mechkumaran45@gmail.com>",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx src/server.ts",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:start": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vite build && esbuild src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "electron:build": "npm run clean && npm run build && tsx copy-assets.ts && electron-builder",
    "electron:build:fast": "npm run build && tsx copy-assets.ts && electron-builder --dir",
    "preview": "vite preview",
    "clean": "rimraf dist release",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/file-saver": "^2.0.7",
    "@vitejs/plugin-react": "^5.0.4",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^3.0.1",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-image-crop": "^11.0.10",
    "react-rnd": "^10.5.3",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "rimraf": "^6.1.3",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "node-domexception": "native"
  },
  "build": {
    "appId": "com.esevai.automator",
    "productName": "esevadraft",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "main-process/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "differentialPackage": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "esevadraft"
    }
  }
}
